{
  "title": "两数之和",
  "time_limit": 1,
  "memory_limit": 256,
  "constraints": [
    "2 <= nums.length <= 10^4",
    "-10^9 <= nums[i] <= 10^9",
    "-10^9 <= target <= 10^9",
    "只存在一个有效答案"
  ],
  "input_format": "第一行: n target\n第二行: n 个整数",
  "output_format": "两个下标（0-based），空格分隔，较小的在前",
  "test_cases": [
    {"input": "4 9\n2 7 11 15", "output": "0 1"},
    {"input": "3 6\n3 2 4",     "output": "1 2"},
    {"input": "2 6\n3 3",       "output": "0 1"}
  ]
}
